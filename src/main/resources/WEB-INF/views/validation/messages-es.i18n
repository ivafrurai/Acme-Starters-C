acme.validation.header.message = Este campo debe tener entre 1 y 75 caracteres (no se admiten solo espacios en blanco).
acme.validation.text.message = Este campo debe tener entre 1 y 255 caracteres (no se admiten solo espacios en blanco).
acme.validation.ticker.message = Este campo debe tener entre 5 y 15 caracteres, admitiendo únicamente letras, números, guiones y guiones bajos.