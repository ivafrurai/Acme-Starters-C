acme.validation.header.message = This field must be between 1 and 75 characters (blank spaces only are not supported).
acme.validation.text.message = This field must be between 1 and 255 characters (blank spaces only are not supported).
acme.validation.ticker.message = This field must be between 5 and 15 characters, supporting only letters, numbers, hyphens, and underscores.