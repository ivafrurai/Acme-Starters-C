acme.validation.text.message   	    = Must have from 1 to 255 characters
acme.validation.header.message   	= Must have from 1 to 75 characters
acme.validation.ticker.message 		= The ticker must start with 2 uppercase letters and 2 digits, followed by a hyphen and 5-10 alphanumeric characters
acme.validation.strategy.duplicated-ticker.message = There is already a strategy with the same ticker.
acme.validation.strategy.tactics.error.message = A Strategy cannot be published unless they have at least one tactic.
acme.validation.strategy.dates.error.message = End date must be after Start date, and Start date must be future.
acme.validation.sponsorship.missing-donations.message = Sponsorships must include at least one donation
acme.validation.sponsorship.invalid-date.message = Sponsorship end date must be after the start date
acme.validation.sponsorship.duplicated-ticker.message = The ticker is already used by another sponsorship
acme.validation.campaign.duplicated-ticker.message = There is already a campaign with the same ticker.
acme.validation.campaign.milestones.error.message = A Campaign cannot be published unless they have at least one milestone.
acme.validation.campaign.dates.error.message = End date must be after Start date, and Start date must be future.
acme.validation.strategy.startMoment.future = Start date must be in the future
acme.validation.strategy.endMoment.future = End date must be in the future
acme.validation.strategy.dates.error = Start/end moments must define a valid time interval
